// ══ DATE UTILS ══
function getMonthFromDate(d){
  const m=d.match(/(\d{2})\.(\d{2})/);
  return m?DEM[parseInt(m[2])]||'?':'?';
}
function dateToSortKey(d){
  const m=d.match(/(\d{2})\.(\d{2})/);
  if(!m)return 99999999;
  const day=parseInt(m[1]),mo=parseInt(m[2]);
  const y1=parseInt((G?G.currentSeason:'2025/26').split('/')[0]);
  return(mo>=7?y1:y1+1)*10000+mo*100+day;
}
function insertSorted(D,sess){
  const k=dateToSortKey(sess.date);
  let at=D.sessions.length;
  for(let i=0;i<D.sessions.length;i++){if(dateToSortKey(D.sessions[i].date)>k){at=i;break;}}
  D.sessions.splice(at,0,sess);
  D.players.forEach(p=>p.s.splice(at,0,3));
}

// ══ SCHEDULE GEN ══
function genRange(s1,s2,tD,mD){
  const p=s=>{const[d,m,y]=s.split('.');return new Date(+y,+m-1,+d);};
  const res=[],start=p(s1),end=p(s2);
  let d=new Date(start);
  while(d<=end){
    const dw=d.getDay(),dd=String(d.getDate()).padStart(2,'0'),mm=String(d.getMonth()+1).padStart(2,'0');
    const lbl=DOW_LBL[dw]+' '+dd+'.'+mm,mo=DEM[d.getMonth()+1];
    if(tD.includes(dw))res.push({date:lbl,month:mo,type:'training',focus:''});
    if(mD.includes(dw))res.push({date:lbl,month:mo,type:'match',homeAway:'home',label:''});
    d.setDate(d.getDate()+1);
  }
  return res;
}

