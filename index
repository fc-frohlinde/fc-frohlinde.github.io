  let csv=['#,Name,Position,'+D.sessions.map(s=>`${s.date}[${s.type==='match'?'Spiel':'T'}${s.focus?'-'+s.focus:''}]`).join(',')];
  D.players.forEach(p=>csv.push(`${p.nr},"${p.name}",${p.pos},${p.s.map(v=>sym[v]).join(',')}`));
  const b=new Blob(['\uFEFF'+csv.join('\n')],{type:'text/csv;charset=utf-8;'});
  const a=document.createElement('a');a.href=URL.createObjectURL(b);a.download=`Anwesenheit_${G.currentTeam}_${G.currentSeason.replace('/','_')}.csv`;a.click();
}
function resetTeam(){if(!confirm(`${G.currentTeam} (${G.currentSeason}) zurücksetzen?`))return;const sess=defaultSessions();G.db[ck()]={sessions:sess,players:mkPlayers(G.currentTeam,sess.length)};save();render();}

// ══ MODALS ══
function openM(id){
  document.getElementById(id).classList.add('open');
  if(id==='moShare')refreshShare();
  if(id==='moSettings'){renderFocusList();renderTeamChecks('atTeamChecks');}
}
function closeM(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.mo').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));

// ══ DOW PICKERS ══
document.querySelectorAll('#dowTr .dow-btn').forEach(b=>b.addEventListener('click',()=>b.classList.toggle('sel')));
document.querySelectorAll('#dowMa .dow-btn').forEach(b=>b.addEventListener('click',()=>b.classList.toggle('sel-m')));

// ══ INIT ══
initData();render();
</script>
