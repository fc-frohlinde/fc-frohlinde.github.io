  </div>
  <div class="mob-btns">
    <button class="btn btn-m" onclick="addMatch()">⚽ Eintragen</button>
    <button class="btn btn-s" onclick="closeM('moMatch')">Abbrechen</button>
  </div>
</div></div>

<!-- Add Team -->
