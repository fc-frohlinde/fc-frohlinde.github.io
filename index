    <div style="display:flex;gap:6px;align-items:center;">
      <input type="number" id="ps-edit-nr" placeholder="Nr" min="1" max="99" style="width:56px;flex:none;margin-bottom:0;"/>
      <input type="text" id="ps-edit-name" placeholder="Name" style="flex:1;margin-bottom:0;"/>
      <select id="ps-edit-pos" style="width:76px;flex:none;margin-bottom:0;">
        <option value="TW">TW</option><option value="RV">RV</option><option value="IV">IV</option>
        <option value="LV">LV</option><option value="6er">6er</option><option value="8er">8er</option>
        <option value="10er">10er</option><option value="RF">RF</option><option value="LF">LF</option>
        <option value="ST">ST</option>
      </select>
      <button class="btn btn-p" onclick="savePlayerEdit()" style="flex:none;">OK</button>
    </div>
    <div style="margin-top:7px;">
      <button class="btn btn-d" onclick="deleteCurrentPlayer()">🗑 Löschen</button>
    </div>
  </div>
</div></div>

<!-- Session Stats -->
<div class="mo" id="moSessStats"><div class="mob" style="width:480px;">
  <div style="display:flex;align-items:flex-start;gap:10px;margin-bottom:13px;">
    <div style="flex:1;">
      <div style="font-family:'Bebas Neue',sans-serif;font-size:1.35rem;color:var(--bd);letter-spacing:2px;line-height:1;" id="ss-title">–</div>
      <div id="ss-meta" style="font-size:.71rem;color:var(--gm);margin-top:3px;"></div>
    </div>
    <button class="btn btn-s" onclick="closeM('moSessStats')">✕</button>
  </div>
  <div style="background:var(--ow);border-radius:8px;padding:9px 11px;border:1px solid var(--gl);margin-bottom:11px;" id="ss-edit-area"></div>
  <div class="ps-cards" id="ss-cards"></div>
  <div class="sec-title">Anwesenheit</div>
  <div class="sess-att-list" id="ss-att-list"></div>
  <div style="display:flex;gap:7px;">
    <button class="btn btn-d" onclick="deleteCurrSess()">🗑 Einheit löschen</button>
    <button class="btn btn-s" onclick="closeM('moSessStats')" style="margin-left:auto;">Schließen</button>
  </div>
</div></div>

<!-- Add Player -->
<div class="mo" id="moAddPlayer"><div class="mob" style="width:330px;">
  <h3>Spieler hinzufügen</h3>
  <label>Trikotnummer</label><input type="number" id="newNr" placeholder="21" min="1" max="99"/>
  <label>Name</label><input type="text" id="newName" placeholder="Vorname Nachname"/>
  <label>Position</label>
  <select id="newPos">
    <option value="TW">TW – Torwart</option><option value="RV">RV – Rechter Verteidiger</option>
    <option value="IV">IV – Innenverteidiger</option><option value="LV">LV – Linker Verteidiger</option>
    <option value="6er">6er – Def. Mittelfeld</option><option value="8er" selected>8er – Zentr. Mittelfeld</option>
