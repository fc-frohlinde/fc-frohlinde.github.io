<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>FC Frohlinde 1949 e.V. – Anwesenheitsliste</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bd:#0d3b7c;--bm:#1659b8;--bl:#2e7de4;
  --wh:#fff;--ow:#f4f7fc;--gl:#e2e9f4;--gm:#a8b8d4;--gd:#4a5d78;
  --ac:#e8c840;--cp:#27ae60;--ca:#e74c3c;--ce:#f39c12;
  --mc1:#b03000;--mc2:#8a2000;
  --sl0:30px;--sl1:145px;--sl2:52px;
  --hdr-h:78px;
}
html,body{height:100%;margin:0;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Barlow',sans-serif;background:linear-gradient(140deg,#071a3e 0%,#1659b8 55%,#071a3e 100%);min-height:100vh;padding:8px;display:flex;flex-direction:column;}
.page{flex:1;display:flex;flex-direction:column;background:var(--wh);border-radius:14px;overflow:hidden;box-shadow:0 6px 30px rgba(0,0,0,.3);min-height:0;}

/* ── HEADER ── */
.header{background:linear-gradient(135deg,#071e48 0%,#1659b8 58%,#0a2d6e 100%);color:#fff;padding:12px 22px;display:flex;align-items:center;gap:16px;flex-shrink:0;position:relative;overflow:hidden;transition:all .25s;}
.header.collapsed{padding:6px 22px;}
.header::before{content:'';position:absolute;right:-40px;top:-40px;width:160px;height:160px;border-radius:50%;background:rgba(255,255,255,.04);}

/* Logo – screen blend removes black background */
.logo-wrap{flex-shrink:0;width:68px;height:68px;z-index:1;transition:all .25s;}
.header.collapsed .logo-wrap{width:36px;height:36px;}
.logo-wrap img{width:100%;height:100%;object-fit:contain;display:block;mix-blend-mode:screen;filter:saturate(1.1) brightness(1.05);}

.htext{z-index:1;transition:all .25s;}
.htext .club{font-family:'Bebas Neue',sans-serif;font-size:1.75rem;letter-spacing:2.5px;line-height:1;transition:all .25s;}
.header.collapsed .htext .club{font-size:1.1rem;}
.htext .sub{font-size:.72rem;font-weight:300;letter-spacing:3.5px;color:var(--ac);margin-top:2px;text-transform:uppercase;transition:all .25s;}
.header.collapsed .htext .sub{font-size:.6rem;margin-top:0;}
.htext .meta{margin-top:3px;font-size:.64rem;color:var(--gm);transition:all .25s;}
.header.collapsed .htext .meta{display:none;}
.hright{margin-left:auto;text-align:right;z-index:1;}
.hright .hl{font-size:.56rem;letter-spacing:1.5px;color:var(--gm);text-transform:uppercase;}
.season-v{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:2px;color:var(--ac);}
.tc-wrap{display:flex;flex-wrap:wrap;gap:3px;justify-content:flex-end;margin-top:4px;max-width:200px;}
.tc{padding:1px 6px;background:rgba(232,200,64,.13);border:1px solid rgba(232,200,64,.28);border-radius:20px;font-size:.6rem;font-weight:600;color:rgba(255,255,255,.85);}
.header.collapsed .hright .hl,.header.collapsed .tc-wrap{display:none;}

/* ── TEAM TABS ── */
.team-bar{background:#07132e;padding:0 22px;display:flex;align-items:stretch;border-bottom:3px solid var(--ac);overflow-x:auto;flex-shrink:0;transition:all .25s;}
.team-bar.collapsed{display:none;}
.ttab{padding:7px 12px;font-family:'Barlow',sans-serif;font-weight:700;font-size:.71rem;letter-spacing:.7px;color:rgba(255,255,255,.4);cursor:pointer;border:none;background:none;text-transform:uppercase;white-space:nowrap;border-bottom:3px solid transparent;margin-bottom:-3px;transition:all .13s;display:flex;align-items:center;gap:4px;}
.ttab:hover{color:#fff;background:rgba(255,255,255,.06);}
.ttab.active{color:var(--ac);border-bottom-color:var(--ac);}
.ttab-add{padding:7px 10px;font-size:.9rem;color:rgba(255,255,255,.24);cursor:pointer;border:none;background:none;align-self:center;}
.ttab-add:hover{color:var(--ac);}
.tdelt{font-size:.53rem;color:rgba(255,255,255,.16);cursor:pointer;padding:1px 3px;border-radius:3px;transition:all .12s;}
.tdelt:hover{background:rgba(231,76,60,.4);color:#fff;}

/* ── BARS ── */
.season-bar{background:#edf2fb;border-bottom:1px solid var(--gl);padding:5px 22px;display:flex;align-items:center;gap:7px;flex-wrap:wrap;flex-shrink:0;transition:all .25s;}
.season-bar.collapsed{display:none;}
.season-bar label{font-size:.62rem;font-weight:700;letter-spacing:1px;color:var(--gd);text-transform:uppercase;}
.ssel{padding:4px 8px;border:1.5px solid var(--gl);border-radius:6px;font-family:'Barlow',sans-serif;font-size:.76rem;font-weight:600;color:var(--bd);background:#fff;cursor:pointer;outline:none;}
.ssel:focus{border-color:var(--bm);}
.bsm{padding:4px 9px;border-radius:6px;border:none;cursor:pointer;font-family:'Barlow',sans-serif;font-size:.68rem;font-weight:600;transition:all .13s;}
.bsm-p{background:var(--ac);color:var(--bd);}.bsm-p:hover{background:#f0d050;}
.bsm-o{background:transparent;color:var(--bm);border:1.5px solid var(--gl);}.bsm-o:hover{border-color:var(--bm);background:rgba(22,89,184,.06);}
.bsm-d{background:transparent;color:var(--ca);border:1.5px solid rgba(231,76,60,.22);}.bsm-d:hover{background:rgba(231,76,60,.08);}

/* ── TOOLBARS (two rows) ── */
/* Row 1: Team management */
.toolbar-team{background:linear-gradient(to right,#0c2450,#1a4fa0);padding:5px 22px;display:flex;gap:5px;flex-wrap:wrap;align-items:center;flex-shrink:0;border-bottom:1px solid rgba(255,255,255,.08);transition:all .25s;}
.toolbar-team.collapsed{display:none;}
/* Row 2: Utility */
.toolbar-util{background:linear-gradient(to right,#091e3e,#0e3577);padding:5px 22px;display:flex;gap:5px;flex-wrap:wrap;align-items:center;flex-shrink:0;transition:all .25s;}
.toolbar-util.collapsed{display:none;}

.btn{padding:5px 10px;border-radius:6px;border:none;cursor:pointer;font-family:'Barlow',sans-serif;font-size:.7rem;font-weight:600;transition:all .13s;display:flex;align-items:center;gap:4px;}
.btn-p{background:var(--ac);color:var(--bd);}.btn-p:hover{background:#f0d050;}
.btn-s{background:rgba(255,255,255,.09);color:#fff;border:1px solid rgba(255,255,255,.17);}.btn-s:hover{background:rgba(255,255,255,.18);}
.btn-d{background:rgba(231,76,60,.11);color:#ff8a80;border:1px solid rgba(231,76,60,.24);}.btn-d:hover{background:rgba(231,76,60,.24);}
.btn-sh{background:rgba(46,204,113,.09);color:#6dffa4;border:1px solid rgba(46,204,113,.22);}.btn-sh:hover{background:rgba(46,204,113,.2);}
.btn-m{background:rgba(176,48,0,.14);color:#ffb38a;border:1px solid rgba(176,48,0,.28);}.btn-m:hover{background:rgba(176,48,0,.28);}
.btn-team{background:rgba(232,200,64,.11);color:var(--ac);border:1px solid rgba(232,200,64,.25);}.btn-team:hover{background:rgba(232,200,64,.2);}
.btn-cfg{background:rgba(255,255,255,.07);color:rgba(255,255,255,.6);border:1px solid rgba(255,255,255,.13);}.btn-cfg:hover{background:rgba(255,255,255,.15);}
.btn-view{background:rgba(46,204,113,.11);color:#6dffa4;border:1px solid rgba(46,204,113,.22);}.btn-view:hover{background:rgba(46,204,113,.2);}
.tsep{width:1px;height:20px;background:rgba(255,255,255,.11);margin:0 1px;}
.saved{font-size:.64rem;color:#7ec8a0;margin-left:auto;opacity:0;transition:opacity .4s;}
.saved.show{opacity:1;}

/* Zoom */
.zoom-group{display:flex;align-items:center;gap:2px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.13);border-radius:6px;padding:2px 4px;}
.z-btn{background:none;border:none;color:rgba(255,255,255,.7);cursor:pointer;font-size:.78rem;font-weight:700;padding:1px 4px;border-radius:4px;transition:all .12s;}
.z-btn:hover{background:rgba(255,255,255,.14);color:#fff;}
.z-lbl{font-size:.64rem;font-weight:700;color:rgba(255,255,255,.7);min-width:30px;text-align:center;}

/* Collapse controls */
.collapse-bar{background:#071430;padding:2px 22px;display:flex;align-items:center;gap:6px;flex-shrink:0;border-bottom:1px solid rgba(255,255,255,.05);}
.cbar-btn{background:none;border:none;color:rgba(255,255,255,.35);cursor:pointer;font-size:.62rem;font-weight:600;padding:2px 8px;border-radius:4px;transition:all .13s;letter-spacing:.3px;}
.cbar-btn:hover{color:#fff;background:rgba(255,255,255,.08);}
.cbar-btn.active{color:var(--ac);}
.cbar-sep{width:1px;height:12px;background:rgba(255,255,255,.1);}
.cbar-label{font-size:.58rem;color:rgba(255,255,255,.25);margin-right:4px;}

/* ── LEGEND ── */
.legend-bar{background:#edf2fb;border-bottom:2px solid var(--gl);padding:5px 22px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;flex-shrink:0;transition:all .25s;}
.legend-bar.collapsed{display:none;}
.legend-bar .lbl{font-size:.61rem;font-weight:700;letter-spacing:1px;color:var(--gd);text-transform:uppercase;}
.li{display:flex;align-items:center;gap:3px;font-size:.67rem;color:var(--gd);font-weight:500;}
.ldot{width:11px;height:11px;border-radius:3px;display:inline-block;flex-shrink:0;}
.lda{background:var(--cp);}.ldf{background:var(--ca);}.lde{background:var(--ce);}.ldq{background:#d5d5d5;border:1px solid var(--gm);}
.lhint{margin-left:auto;font-size:.62rem;color:var(--gm);font-style:italic;}

/* ── TABLE ── */
.table-wrap{flex:1;overflow:auto;min-height:0;position:relative;}
table{width:100%;border-collapse:separate;border-spacing:0;font-size:.74rem;}

/* sticky left */
.sl0,.sl1,.sl2{position:sticky;z-index:3;}
.sl0{left:0;width:var(--sl0);min-width:var(--sl0);background:#fff;}
.sl1{left:var(--sl0);min-width:var(--sl1);width:var(--sl1);background:#fff;}
.sl2{left:calc(var(--sl0) + var(--sl1));width:var(--sl2);min-width:var(--sl2);background:#fff;}
tbody tr:nth-child(even) .sl0,tbody tr:nth-child(even) .sl1,tbody tr:nth-child(even) .sl2{background:#f6f9fe;}
tbody tr:hover .sl0,tbody tr:hover .sl1,tbody tr:hover .sl2{background:#d8eaff !important;}

/* thead */
thead tr:first-child th{background:var(--bd);color:#fff;font-family:'Bebas Neue',sans-serif;font-size:.73rem;letter-spacing:1.5px;padding:8px 3px;text-align:center;white-space:nowrap;position:sticky;top:0;z-index:10;}
thead tr:first-child th.thp{text-align:left;padding-left:7px;}
thead tr:nth-child(2) th{background:var(--bm);color:#fff;font-size:.6rem;font-weight:600;padding:4px 3px;text-align:center;white-space:nowrap;border-bottom:3px solid var(--ac);position:sticky;top:35px;z-index:10;}
thead tr:nth-child(2) th.thp{text-align:left;padding-left:7px;}
thead th.sl0,thead th.sl1,thead th.sl2{z-index:14 !important;}
.mg-hdr-match{background:var(--mc2)!important;}
thead tr:nth-child(2) .mg-hdr-match{background:var(--mc1)!important;}

/* tfoot */
tfoot td{background:#0d2d5e;color:#fff;font-weight:600;font-size:.69rem;padding:6px 3px;text-align:center;border-top:3px solid var(--ac);position:sticky;bottom:0;z-index:10;white-space:nowrap;}
tfoot td.tdl{text-align:left;padding-left:7px;}
tfoot td.sl0,tfoot td.sl1,tfoot td.sl2{z-index:14!important;background:#0a2550!important;}
tfoot td.mg-hdr-match{background:#4a1000!important;}

/* Month borders */
.mg-start{border-left:2px solid rgba(22,89,184,.22)!important;}
.mg-start-match{border-left:2px solid rgba(176,48,0,.28)!important;}
thead th.mg-start{border-left:2px solid rgba(255,255,255,.16)!important;}
tfoot td.mg-start{border-left:2px solid rgba(232,200,64,.18)!important;}

/* Body rows */
tbody tr:nth-child(odd){background:#fff;}
tbody tr:nth-child(even){background:#f6f9fe;}
tbody tr:hover{background:#d8eaff;}
tbody td{padding:6px 3px;text-align:center;border-bottom:1px solid var(--gl);color:#2c3e50;font-weight:500;}
tbody td.tdl{text-align:left;padding-left:7px;}

.nri{width:22px;background:transparent;border:none;outline:none;font-weight:700;color:var(--bm);font-size:.74rem;text-align:center;cursor:text;}
.ncell{cursor:pointer;display:flex;align-items:center;gap:3px;}
.ncell .nm{font-weight:600;color:var(--bd);font-size:.74rem;transition:color .12s;}
.ncell .ni{font-size:.61rem;color:var(--gm);opacity:0;transition:opacity .12s;}
tbody td:hover .ncell .nm{color:var(--bm);}
tbody td:hover .ncell .ni{opacity:1;}

/* Positions */
.pw{position:relative;display:inline-block;}
.pb{display:inline-block;padding:1px 4px;border-radius:10px;font-size:.56rem;font-weight:700;cursor:pointer;user-select:none;white-space:nowrap;}
.pb-TW{background:#ffeaa7;color:#7a5a00;}.pb-RV{background:#cce5ff;color:#004080;}
.pb-IV{background:#b0cce0;color:#003060;}.pb-LV{background:#cce5ff;color:#004080;}
.pb-6er{background:#c3e6cb;color:#155724;}.pb-8er{background:#a0d8a8;color:#0d4020;}
.pb-10er{background:#7cc884;color:#083010;}.pb-RF{background:#ffe0b0;color:#7a3a00;}
.pb-LF{background:#ffd0b0;color:#7a3a00;}.pb-ST{background:#ffd6d6;color:#8a0000;}
.pmenu{display:none;position:absolute;top:20px;left:0;z-index:30;background:#fff;border:1px solid var(--gl);border-radius:7px;box-shadow:0 4px 14px rgba(0,0,0,.14);overflow:hidden;min-width:165px;}
.pmenu.open{display:block;}
.pmi{padding:4px 8px;cursor:pointer;font-size:.66rem;font-weight:600;white-space:nowrap;display:flex;align-items:center;gap:5px;}
.pmi:hover{background:var(--ow);}

/* Status cells */
.cs{cursor:pointer;border-radius:4px;user-select:none;transition:transform .1s;font-weight:700;min-width:20px;font-size:.68rem;}
.cs:hover{transform:scale(1.3);}
.csa{background:var(--cp)!important;color:#fff!important;}
.csf{background:var(--ca)!important;color:#fff!important;}
.cse{background:var(--ce)!important;color:#fff!important;}
.csq{background:#e0e0e0!important;color:#999!important;font-size:.62rem;}

/* Date header */
.dth{position:relative;cursor:pointer;user-select:none;}
.dth:hover{filter:brightness(1.15);}
.d-text{display:block;font-size:.59rem;font-weight:700;color:#fff;text-align:center;padding:0 2px;white-space:nowrap;}
.d-focus{display:block;font-size:.5rem;color:rgba(255,255,255,.62);text-align:center;margin-top:1px;white-space:nowrap;max-width:46px;overflow:hidden;text-overflow:ellipsis;}
.dcb{display:none;position:absolute;top:0;right:0;background:rgba(231,76,60,.85);color:#fff;border:none;border-radius:2px;cursor:pointer;font-size:.48rem;padding:1px 3px;line-height:1.4;z-index:1;}
.dth:hover .dcb{display:block;}
.drb{background:none;border:none;cursor:pointer;color:transparent;font-size:.77rem;padding:2px 3px;border-radius:3px;transition:all .12s;}
tbody tr:hover .drb{color:var(--gm);}
.drb:hover{background:rgba(231,76,60,.1);color:var(--ca)!important;}
.mhdr-lbl{font-size:.61rem;font-weight:700;letter-spacing:.8px;text-transform:uppercase;}

/* FOOTER */
.footer{background:#edf2fb;border-top:2px solid var(--gl);padding:7px 22px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:6px;flex-shrink:0;}
.fstats{display:flex;gap:11px;}
.si .v{font-family:'Bebas Neue',sans-serif;font-size:1.15rem;color:var(--bd);line-height:1;}
.si .k{font-size:.57rem;font-weight:600;letter-spacing:1px;color:var(--gd);text-transform:uppercase;}
.footer .sign{font-size:.63rem;color:var(--gm);}
.footer .sign span{color:var(--bm);font-weight:600;}
.empty{padding:28px;text-align:center;color:var(--gm);}

/* ══ MODALS ══ */
.mo{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:200;align-items:center;justify-content:center;backdrop-filter:blur(2px);}
.mo.open{display:flex;}
.mob{background:#fff;border-radius:14px;padding:18px 22px;max-width:96vw;box-shadow:0 10px 44px rgba(0,0,0,.25);max-height:92vh;overflow-y:auto;}
.mob h3{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:var(--bd);letter-spacing:2px;margin-bottom:11px;}
.mob label{display:block;font-size:.66rem;font-weight:700;color:var(--gd);margin-bottom:3px;text-transform:uppercase;letter-spacing:.4px;}
.mob input,.mob select,.mob textarea{width:100%;padding:7px 10px;border:1.5px solid var(--gl);border-radius:7px;font-family:'Barlow',sans-serif;font-size:.8rem;margin-bottom:9px;outline:none;color:#2c3e50;transition:border-color .13s;}
.mob input:focus,.mob select:focus,.mob textarea:focus{border-color:var(--bm);}
.mob .note{font-size:.66rem;color:var(--gm);margin-bottom:8px;line-height:1.5;}
.mob-btns{display:flex;gap:6px;margin-top:6px;flex-wrap:wrap;}
.mob-btns .btn{flex:1;justify-content:center;min-width:84px;}
.mob-hr{border:none;border-top:1px solid var(--gl);margin:9px 0;}
.radio-group{display:flex;gap:7px;margin-bottom:9px;}
.radio-opt{display:flex;align-items:center;gap:5px;padding:5px 11px;border:1.5px solid var(--gl);border-radius:7px;cursor:pointer;font-size:.76rem;font-weight:600;color:var(--gd);transition:all .13s;}
.radio-opt.sel-m{border-color:var(--mc1);background:rgba(176,48,0,.07);color:var(--mc1);}
.dow-grid{display:flex;gap:4px;margin-bottom:9px;flex-wrap:wrap;}
.dow-btn{padding:4px 8px;border:1.5px solid var(--gl);border-radius:6px;cursor:pointer;font-family:'Barlow',sans-serif;font-size:.69rem;font-weight:700;color:var(--gd);background:#fff;transition:all .13s;user-select:none;}
.dow-btn.sel{border-color:var(--bm);background:rgba(22,89,184,.1);color:var(--bm);}
.dow-btn.sel-m{border-color:var(--mc1);background:rgba(176,48,0,.08);color:var(--mc1);}
.team-checks{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:9px;}
.tcheck{display:flex;align-items:center;gap:4px;padding:4px 9px;border:1.5px solid var(--gl);border-radius:6px;cursor:pointer;font-size:.7rem;font-weight:600;color:var(--gd);transition:all .13s;user-select:none;}
.tcheck.sel{border-color:var(--bm);background:rgba(22,89,184,.09);color:var(--bm);}
.tab-bar{display:flex;gap:0;border-bottom:2px solid var(--gl);margin-bottom:11px;}
.tab-btn{padding:6px 14px;font-family:'Barlow',sans-serif;font-weight:700;font-size:.71rem;letter-spacing:.5px;color:var(--gm);cursor:pointer;border:none;background:none;text-transform:uppercase;border-bottom:2.5px solid transparent;margin-bottom:-2px;transition:all .13s;}
.tab-btn:hover{color:var(--bm);}
.tab-btn.active{color:var(--bm);border-bottom-color:var(--bm);}
.tab-panel{display:none;}
.tab-panel.active{display:block;}

/* Player/Session stats */
.ps-cards{display:flex;gap:7px;margin-bottom:12px;flex-wrap:wrap;}
.ps-card{flex:1;min-width:100px;background:var(--ow);border-radius:8px;padding:9px 11px;border:1px solid var(--gl);}
.ps-card .ct{font-size:.58rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--gm);margin-bottom:3px;}
.ps-card .cv{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;line-height:1;}
.ps-card .ca2{font-size:.66rem;color:var(--gm);margin-bottom:5px;}
.cbw{background:var(--gl);border-radius:3px;height:6px;}
.cbar{height:6px;border-radius:3px;}
.focus-row{display:flex;align-items:center;gap:6px;margin-bottom:5px;font-size:.7rem;}
.fr-name{width:80px;color:var(--gd);font-weight:600;font-size:.65rem;}
.fr-bw{flex:1;background:var(--gl);border-radius:3px;height:5px;}
.fr-bar{height:5px;border-radius:3px;background:var(--bm);}
.fr-val{width:38px;text-align:right;font-weight:700;color:var(--bd);}
.sess-list{max-height:150px;overflow-y:auto;border:1px solid var(--gl);border-radius:7px;margin-bottom:11px;}
.sr{display:flex;align-items:center;gap:6px;padding:5px 9px;border-bottom:1px solid var(--gl);font-size:.7rem;}
.sr:last-child{border-bottom:none;}
.sr:nth-child(even){background:#f8fafd;}
.sr-date{width:52px;color:var(--gd);font-weight:600;}
.sr-type{padding:1px 5px;border-radius:9px;font-size:.56rem;font-weight:700;}
.srt-t{background:rgba(22,89,184,.11);color:var(--bm);}
.srt-m{background:rgba(176,48,0,.12);color:var(--mc1);}
.sr-st{margin-left:auto;padding:2px 6px;border-radius:4px;font-size:.62rem;font-weight:700;}
.ss-a{background:var(--cp);color:#fff;}.ss-f{background:var(--ca);color:#fff;}
.ss-e{background:var(--ce);color:#fff;}.ss-q{background:#e0e0e0;color:#888;}
.sess-att-list{max-height:280px;overflow-y:auto;border:1px solid var(--gl);border-radius:7px;margin-bottom:10px;}
.sat-row{display:flex;align-items:center;gap:6px;padding:5px 9px;border-bottom:1px solid var(--gl);font-size:.71rem;}
.sat-row:last-child{border-bottom:none;}
.sat-row:nth-child(even){background:#f8fafd;}
.sat-nr{width:22px;font-weight:700;color:var(--bm);text-align:center;}
.sat-name{flex:1;font-weight:600;color:var(--bd);}
.sat-pos{width:34px;}
.sat-st{padding:2px 8px;border-radius:4px;font-size:.63rem;font-weight:700;cursor:pointer;transition:transform .1s;}
.sat-st:hover{transform:scale(1.1);}
.rkrow{display:flex;align-items:center;gap:6px;padding:4px 0;border-bottom:1px solid var(--gl);font-size:.71rem;}
.rkrow:last-child{border-bottom:none;}
.rk-i{width:15px;font-family:'Bebas Neue',sans-serif;font-size:.8rem;color:var(--gm);}
.rk-n{flex:1;font-weight:600;color:var(--bd);}
.rk-bw{width:66px;background:var(--gl);border-radius:3px;height:5px;}
.rk-bar{height:5px;border-radius:3px;}
.rk-pct{width:32px;text-align:right;font-weight:700;}
.full-table{width:100%;font-size:.71rem;border-collapse:separate;border-spacing:0;}
.full-table th{background:var(--bd);color:#fff;font-family:'Bebas Neue',sans-serif;font-size:.72rem;padding:6px 7px;text-align:center;cursor:pointer;user-select:none;white-space:nowrap;}
.full-table th:hover{background:var(--bm);}
.full-table td{padding:5px 7px;border-bottom:1px solid var(--gl);text-align:center;color:#2c3e50;}
.full-table tr:nth-child(even) td{background:#f6f9fe;}
.full-table tr:hover td{background:#ddeeff;}
.tr-row{display:flex;align-items:center;gap:7px;padding:6px 9px;background:var(--ow);border-radius:7px;margin-bottom:5px;}
.tr-name{flex:1;font-weight:600;color:var(--bd);font-size:.76rem;}
.tr-teams{font-size:.63rem;color:var(--gm);}
.tr-del{background:none;border:none;cursor:pointer;color:var(--gm);font-size:.82rem;padding:2px 3px;border-radius:3px;transition:all .13s;}
.tr-del:hover{background:rgba(231,76,60,.1);color:var(--ca);}
.focus-item{display:flex;align-items:center;gap:7px;padding:6px 9px;background:var(--ow);border-radius:7px;margin-bottom:5px;}
.fi-name{flex:1;font-weight:600;color:var(--bd);font-size:.76rem;}
.fi-del{background:none;border:none;cursor:pointer;color:var(--gm);font-size:.82rem;padding:2px 3px;border-radius:3px;transition:all .13s;}
.fi-del:hover{background:rgba(231,76,60,.1);color:var(--ca);}
.pl-row{display:flex;align-items:center;gap:7px;padding:6px 9px;border-bottom:1px solid var(--gl);font-size:.72rem;}
.pl-row:last-child{border-bottom:none;}
.pl-row:nth-child(even){background:#f8fafd;}
.pl-nr{width:25px;text-align:center;font-weight:700;color:var(--bm);}
.pl-name{flex:1;font-weight:600;color:var(--bd);}
.pl-pos{width:38px;}
.pl-btns{display:flex;gap:3px;}
.pl-btn{padding:3px 6px;border-radius:5px;border:none;cursor:pointer;font-size:.63rem;font-weight:600;transition:all .12s;}
.pl-btn-e{background:rgba(22,89,184,.1);color:var(--bm);}.pl-btn-e:hover{background:rgba(22,89,184,.2);}
.pl-btn-d{background:rgba(231,76,60,.1);color:var(--ca);}.pl-btn-d:hover{background:rgba(231,76,60,.2);}
.sec-title{font-size:.64rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--gd);margin-bottom:6px;}
.sc-box{font-family:monospace;font-size:.61rem;background:#f0f4fc;border:1px solid var(--gl);border-radius:6px;padding:6px;word-break:break-all;max-height:62px;overflow-y:auto;color:#334;margin-bottom:6px;}
.sm-btns{display:flex;gap:5px;margin-bottom:7px;}
.smode{padding:4px 10px;border-radius:5px;border:1.5px solid var(--gl);background:transparent;cursor:pointer;font-family:'Barlow',sans-serif;font-size:.68rem;font-weight:600;color:var(--gd);transition:all .13s;}
.smode.active{border-color:var(--bm);background:rgba(22,89,184,.08);color:var(--bm);}

@media print{
  body{background:#fff;padding:0;height:auto;display:block;}
  .page{height:auto;overflow:visible;border-radius:0;box-shadow:none;}
  .collapse-bar,.toolbar-team,.toolbar-util,.season-bar .bsm,.mo{display:none!important;}
  .table-wrap{max-height:none!important;overflow:visible!important;flex:none;}
  .sl0,.sl1,.sl2{position:static!important;}
  tfoot td,thead th{position:static!important;}
}
</style>
</head>
<body>
<div class="page" id="mainPage">

<!-- HEADER -->
<div class="header" id="hdrEl">
  <div class="logo-wrap"><img id="clogo" alt="FC Frohlinde 1949"/></div>
  <div class="htext">
    <div class="club">FC Frohlinde 1949 e.V.</div>
    <div class="sub" id="hSub">U19 · Junioren</div>
    <div class="meta">Anwesenheits- &amp; Spielerliste</div>
  </div>
  <div class="hright">
    <div class="hl">Saison</div>
    <div class="season-v" id="hSeason">2025/26</div>
    <div class="hl" style="margin-top:5px;">Trainer</div>
    <div class="tc-wrap" id="hTrainers"></div>
  </div>
</div>

<!-- TEAM TABS -->
<div class="team-bar" id="teamBarEl"></div>

<!-- SEASON BAR -->
<div class="season-bar" id="seasonBarEl">
