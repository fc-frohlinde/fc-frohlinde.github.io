      <button class="btn btn-p" onclick="addFocus()" style="flex:none;">＋</button>
    </div>
  </div>
  <div class="tab-panel" id="stab-all-trainers">
    <p class="note">Übersicht aller Trainer.</p>
    <div id="all-trainers-list" style="margin-bottom:9px;"></div>
    <hr class="mob-hr"/>
    <label>Name</label><input type="text" id="atNewName" placeholder="Vorname Nachname"/>
    <label>Mannschaft(en)</label>
    <div class="team-checks" id="atTeamChecks"></div>
    <div class="mob-btns">
      <button class="btn btn-p" onclick="addTrainerGlobal()">Hinzufügen</button>
      <button class="btn btn-s" onclick="closeM('moSettings')">Schließen</button>
    </div>
  </div>
</div></div>

<!-- Share -->
<div class="mo" id="moShare"><div class="mob" style="width:390px;">
  <h3>🔗 Teilen</h3>
  <p class="note"><strong id="shareTeamLbl">–</strong> · <strong id="shareSeasonLbl">–</strong></p>
  <div class="sm-btns">
    <button class="smode active" id="smE" onclick="setShareMode('edit')">✏️ Bearbeiten</button>
    <button class="smode" id="smV" onclick="setShareMode('view')">👁 Nur ansehen</button>
  </div>
  <div class="sc-box" id="shareBox">–</div>
  <div style="display:flex;gap:6px;margin-bottom:11px;flex-wrap:wrap;">
    <button class="btn btn-p" onclick="copyCode()">📋 Kopieren</button>
