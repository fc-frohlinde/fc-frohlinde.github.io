  const raw=document.getElementById('importBox').value.trim();if(!raw)return alert('Code einfügen.');
  try{
    const p=JSON.parse(decodeURIComponent(escape(atob(raw))));
    if(!p.team||!p.season||!p.sessions||!p.players)throw 0;
    if(!G.teamList.includes(p.team))G.teamList.push(p.team);
    if(!G.seasonList.includes(p.season))G.seasonList.push(p.season);
    G.db[p.team+'__'+p.season]={sessions:p.sessions,players:p.players};
    if(p.trainers)G.trainers=p.trainers;
    G.currentTeam=p.team;G.currentSeason=p.season;save();render();closeM('moShare');alert(`${p.team} (${p.season}) importiert!`);
  }catch(e){alert('Ungültiger Code.');}
