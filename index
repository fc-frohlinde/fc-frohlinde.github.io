let statsSort={col:'pct',asc:false};
function renderTmgrStats(){
  const D=cd(),ss=D.sessions;
  const tS=ss.filter(s=>s.type==='training').length,mS=ss.filter(s=>s.type==='match').length;
  let totA=0,totPl=0;D.players.forEach(p=>{totA+=p.s.filter(v=>v===1).length;totPl+=p.s.filter(v=>v!==3).length;});
  const avg=totPl?Math.round((totA/totPl)*100):0;
  const rows=D.players.map(p=>{
    const tIdx=ss.map((s,i)=>s.type==='training'?i:-1).filter(i=>i>=0);
    const mIdx=ss.map((s,i)=>s.type==='match'?i:-1).filter(i=>i>=0);
    const tA=tIdx.filter(i=>p.s[i]===1).length,tPl=tIdx.filter(i=>p.s[i]!==3).length;
    const mA=mIdx.filter(i=>p.s[i]===1).length,mPl=mIdx.filter(i=>p.s[i]!==3).length;
    const tPct=tPl?Math.round((tA/tPl)*100):0,mPct=mPl?Math.round((mA/mPl)*100):0;
    return{nr:p.nr,name:p.name,pos:p.pos,tA,tPl,tPct,mA,mPl,mPct,pct:tPct};
  });
  rows.sort((a,b)=>{const v=statsSort.col;const r=typeof a[v]==='string'?a[v].localeCompare(b[v]):a[v]-b[v];return statsSort.asc?r:-r;});
  const sa=c=>statsSort.col===c?(statsSort.asc?'↑':'↓'):'';
  const th=(c,l)=>`<th onclick="sortStats('${c}')">${l} ${sa(c)}</th>`;
  document.getElementById('tmgr-stats').innerHTML=`
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:7px;margin-bottom:12px;">
      <div class="ps-card"><div class="ct">Spieler</div><div class="cv">${D.players.length}</div></div>
      <div class="ps-card"><div class="ct">Trainings</div><div class="cv">${tS}</div></div>
      <div class="ps-card"><div class="ct">Spiele</div><div class="cv">${mS}</div></div>
      <div class="ps-card"><div class="ct">Ø-Quote</div><div class="cv" style="color:${avg>=80?'var(--cp)':avg>=60?'var(--ce)':'var(--ca)'};">${avg}%</div></div>
    </div>
    <div style="max-height:280px;overflow-y:auto;border:1px solid var(--gl);border-radius:7px;">
    <table class="full-table"><thead><tr>${th('nr','#')}${th('name','Spieler')}${th('pos','Pos.')}${th('tPct','T%')}${th('tA','T-A')}${th('tPl','T-∑')}${mS?th('mPct','S%')+th('mA','S-A')+th('mPl','S-∑'):''}</tr></thead>
    <tbody>${rows.map(r=>{const bc=r.tPct>=80?'var(--cp)':r.tPct>=60?'var(--ce)':'var(--ca)';return`<tr>
      <td>${r.nr}</td>
      <td style="text-align:left;cursor:pointer;" onclick="closeM('moTeamMgr');openPlayerStats(${D.players.findIndex(p=>p.name===r.name)});">${r.name}</td>
      <td><span class="pb pb-${r.pos}">${r.pos}</span></td>
      <td style="font-weight:700;color:${bc};">${r.tPl?r.tPct+'%':'–'}</td>
      <td>${r.tA}</td><td>${r.tPl}</td>
      ${mS?`<td style="font-weight:700;color:${r.mPct>=80?'var(--cp)':r.mPct>=60?'var(--ce)':'var(--ca)'};">${r.mPl?r.mPct+'%':'–'}</td><td>${r.mA}</td><td>${r.mPl}</td>`:''}
    </tr>`;}).join('')}</tbody></table></div>`;
}
