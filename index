};
function mkPlayers(team,n){return(DEF_PLAYERS[team]||[]).map(p=>({...p,s:new Array(n).fill(3)}));}
function defaultSessions(){return genRange('24.03.2026','30.06.2026',[2,4],[0]).sort((a,b)=>dateToSortKey(a.date)-dateToSortKey(b.date));}

// ══ STORAGE ══
let G;
function initData(){
  try{G=JSON.parse(localStorage.getItem(SK));}catch(e){G=null;}
  if(!G||!G.version||G.version<10){
    const sess=defaultSessions();
    G={version:10,currentTeam:'U19',currentSeason:'2025/26',
      teamList:[...DEF_TEAMS],seasonList:['2025/26'],
      trainers:[
        {id:'t1',name:'Max Mustermann',teams:['U19']},
        {id:'t2',name:'Hans Schmidt',teams:['U17','U16']},
        {id:'t3',name:'Klaus Berger',teams:['U15','U14']},
      ],
      db:{}};
    // Per-team focuses stored IN the team db key under a special entry
    G.teamList.forEach(t=>{
      G.db[t+'__2025/26']={sessions:JSON.parse(JSON.stringify(sess)),players:mkPlayers(t,sess.length)};
      G.db[t+'__focuses']=[...DEF_FOCUSES]; // per-team focuses, season-independent
    });
  }
  // Ensure focuses exist for all teams
  G.teamList.forEach(t=>{if(!G.db[t+'__focuses'])G.db[t+'__focuses']=[...DEF_FOCUSES];});
  save(false);
}
function save(badge=true){
  localStorage.setItem(SK,JSON.stringify(G));
  if(badge){const b=document.getElementById('savedBadge');b.classList.add('show');clearTimeout(b._t);b._t=setTimeout(()=>b.classList.remove('show'),1700);}
}
function ck(){return G.currentTeam+'__'+G.currentSeason;}
function cd(){if(!G.db[ck()])G.db[ck()]={sessions:[],players:[]};return G.db[ck()];}
function teamFocuses(t){t=t||G.currentTeam;if(!G.db[t+'__focuses'])G.db[t+'__focuses']=[...DEF_FOCUSES];return G.db[t+'__focuses'];}

// ══ RENDER ══
function render(){renderTeamBar();renderSeasonSel();renderHeaderInfo();renderHead();renderBody();renderTfoot();renderFooter();populateFocusSelect();}

function renderHeaderInfo(){
  document.getElementById('hSeason').textContent=G.currentSeason;
  document.getElementById('hSub').textContent=G.currentTeam+' · Junioren';
  document.getElementById('fDate').textContent=new Date().toLocaleDateString('de-DE',{day:'2-digit',month:'2-digit',year:'numeric'});
