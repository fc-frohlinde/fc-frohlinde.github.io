}

function buildMeta(ss){
  let curMo=null;
  return ss.map(s=>{const mo=getMonthFromDate(s.date);const first=mo!==curMo;if(first)curMo=mo;return{mo,first};});
}

function renderHead(){
  const D=cd(),ss=D.sessions,meta=buildMeta(ss);
  const grps=[];
  ss.forEach((s,i)=>{if(meta[i].first)grps.push({mo:meta[i].mo,count:1});else grps[grps.length-1].count++;});
  let r1=`<tr>
    <th rowspan="2" class="thp sl0" style="background:var(--bd);">#</th>
    <th rowspan="2" class="thp sl1" style="background:var(--bd);">Spieler</th>
    <th rowspan="2" class="thp sl2" style="background:var(--bd);">Pos.</th>`;
  grps.forEach((g,gi)=>{r1+=`<th colspan="${g.count}" ${gi%2===1?'style="background:#0a2d6e;"':''}><span class="mhdr-lbl">${g.mo}</span></th>`;});
  if(!ss.length)r1+='<th></th>';
  r1+=`<th rowspan="2" style="width:20px;background:var(--bd);"></th></tr>`;
  let r2='<tr>';
  ss.forEach((s,i)=>{
    const isMat=s.type==='match';
    const sc=meta[i].first?(isMat?'mg-start-match':'mg-start'):'';
    const sub=isMat?(s.homeAway==='home'?'🏠':'✈'):(s.focus||'');
    r2+=`<th class="dth ${isMat?'mg-hdr-match':''} ${sc}" onclick="openSessStats(${i})">
      <span class="d-text">${s.date}</span>
      ${sub?`<span class="d-focus">${sub}</span>`:''}
      <button class="dcb" onclick="event.stopPropagation();delSess(${i})">✕</button>
    </th>`;
  });
  if(!ss.length)r2+='<th style="background:var(--bm);"></th>';
  r2+='</tr>';
  document.getElementById('tHead').innerHTML=r1+r2;
}

function renderBody(){
  const D=cd(),tbody=document.getElementById('tBody');
  const ss=D.sessions,meta=buildMeta(ss);
  if(!D.players.length){
    tbody.innerHTML=`<tr><td colspan="${ss.length+4}" class="empty"><div style="font-size:1.8rem;margin-bottom:5px;">👥</div><p>Keine Spieler vorhanden.</p></td></tr>`;
    return;
  }
  tbody.innerHTML='';
  D.players.forEach((p,pi)=>{
    const cells=p.s.map((v,si)=>{
      const isMat=ss[si].type==='match';
      const sc=meta[si].first?(isMat?'mg-start-match':'mg-start'):'';
      return `<td class="cs ${CLS[v]} ${sc}" data-pi="${pi}" data-si="${si}" onclick="cycSt(${pi},${si})">${SYM[v]}</td>`;
    }).join('');
    const tr=document.createElement('tr');
    tr.innerHTML=`
      <td class="tdl sl0"><input class="nri" value="${p.nr}" onchange="updNr(${pi},this.value)"/></td>
      <td class="tdl sl1" onclick="openPlayerStats(${pi})" style="cursor:pointer;">
        <div class="ncell"><span class="nm">${p.name}</span><span class="ni">›</span></div>
      </td>
      <td class="sl2"><div class="pw">
        <span class="pb pb-${p.pos}" onclick="togPos(${pi},event)">${p.pos}</span>
        <div class="pmenu" id="pm${pi}">${POS_LIST.map(pos=>`<div class="pmi" onclick="setPos(${pi},'${pos}')"><span class="pb pb-${pos}" style="pointer-events:none;">${pos}</span>${POS_LBL[pos]}</div>`).join('')}</div>
      </div></td>
      ${cells}
      <td><button class="drb" onclick="delPlayer(${pi})">✕</button></td>`;
    tbody.appendChild(tr);
  });
}

function renderTfoot(){
  const D=cd(),ss=D.sessions,meta=buildMeta(ss);
  if(!ss.length||!D.players.length){document.getElementById('tFoot').innerHTML='';return;}
  const cells=ss.map((_,si)=>{
    const c=D.players.filter(p=>p.s[si]===1).length;
    const pct=D.players.length?Math.round((c/D.players.length)*100):0;
    const isMat=ss[si].type==='match';
    const sc=meta[si].first?(isMat?'mg-start-match':'mg-start'):'';
    return `<td class="${isMat?'mg-hdr-match':''} ${sc}">
      <span style="font-weight:700;color:${isMat?'#ffb38a':'var(--ac)'};">${c}</span>
      <span style="display:block;font-size:.54rem;opacity:.65;">${pct}%</span>
    </td>`;
  }).join('');
  let totA=0,totPl=0;
  D.players.forEach(p=>{totA+=p.s.filter(v=>v===1).length;totPl+=p.s.filter(v=>v!==3).length;});
  const avg=totPl?Math.round((totA/totPl)*100):0;
  document.getElementById('tFoot').innerHTML=`<tr>
    <td class="tdl sl0" style="font-family:'Bebas Neue';letter-spacing:1px;">∑</td>
    <td class="tdl sl1" style="font-size:.66rem;opacity:.75;">${D.players.length} Spieler · Ø ${avg}%</td>
    <td class="sl2"></td>${cells}<td></td>
  </tr>`;
}

function renderFooter(){
  const D=cd();
  const tS=D.sessions.filter(s=>s.type==='training').length,mS=D.sessions.filter(s=>s.type==='match').length;
  let totA=0,totPl=0;
  D.players.forEach(p=>{totA+=p.s.filter(v=>v===1).length;totPl+=p.s.filter(v=>v!==3).length;});
  const avg=totPl?Math.round((totA/totPl)*100):0;
  document.getElementById('fStats').innerHTML=`
    <div class="si"><div class="v">${D.players.length}</div><div class="k">Spieler</div></div>
    <div class="si"><div class="v">${tS}</div><div class="k">Trainings</div></div>
    <div class="si"><div class="v">${mS}</div><div class="k">Spiele</div></div>
    <div class="si"><div class="v">${avg}%</div><div class="k">Ø-Quote</div></div>`;
  document.getElementById('fTeam').textContent=G.currentTeam+' · Saison '+G.currentSeason;
}

// ══ PLAYER STATS ══
function openPlayerStats(pi){
  currentPI=pi;
  const D=cd(),p=D.players[pi],ss=D.sessions,foc=teamFocuses();
  document.getElementById('ps-name').textContent=p.name;
  document.getElementById('ps-nr').textContent='#'+p.nr;
  document.getElementById('ps-pos-badge').innerHTML=`<span class="pb pb-${p.pos}">${p.pos} – ${POS_LBL[p.pos]}</span>`;
  document.getElementById('ps-team-badge').textContent=G.currentTeam+' · '+G.currentSeason;
  document.getElementById('ps-edit-nr').value=p.nr;
  document.getElementById('ps-edit-name').value=p.name;
  document.getElementById('ps-edit-pos').value=p.pos;
  const tIdx=ss.map((s,i)=>s.type==='training'?i:-1).filter(i=>i>=0);
  const mIdx=ss.map((s,i)=>s.type==='match'?i:-1).filter(i=>i>=0);
  const tA=tIdx.filter(i=>p.s[i]===1).length,tPl=tIdx.filter(i=>p.s[i]!==3).length;
  const mA=mIdx.filter(i=>p.s[i]===1).length,mPl=mIdx.filter(i=>p.s[i]!==3).length;
  const tPct=tPl?Math.round((tA/tPl)*100):0,mPct=mPl?Math.round((mA/mPl)*100):0;
  const tBc=tPct>=80?'var(--cp)':tPct>=60?'var(--ce)':'var(--ca)';
  const mBc=mPct>=80?'var(--cp)':mPct>=60?'var(--ce)':'var(--ca)';
  document.getElementById('ps-cards').innerHTML=`
    <div class="ps-card"><div class="ct">Training</div><div class="cv" style="color:${tBc};">${tPl?tPct+'%':'–'}</div><div class="ca2">${tA}/${tPl}</div><div class="cbw"><div class="cbar" style="width:${Math.min(tPct,100)}%;background:${tBc};"></div></div></div>
    ${mPl?`<div class="ps-card"><div class="ct" style="color:var(--mc1);">⚽ Spiele</div><div class="cv" style="color:${mBc};">${mPct}%</div><div class="ca2">${mA}/${mPl}</div><div class="cbw"><div class="cbar" style="width:${Math.min(mPct,100)}%;background:${mBc};"></div></div></div>`:''}`;
  // Monthly
  const moMap={};
  ss.forEach((s,i)=>{const mo=getMonthFromDate(s.date);if(!moMap[mo])moMap[mo]={tA:0,tPl:0,mA:0,mPl:0};const v=p.s[i];if(s.type==='training'){if(v!==3)moMap[mo].tPl++;if(v===1)moMap[mo].tA++;}else{if(v!==3)moMap[mo].mPl++;if(v===1)moMap[mo].mA++;}});
  document.getElementById('ps-months').innerHTML=Object.entries(moMap).map(([mo,st])=>{
    const pct=st.tPl?Math.round((st.tA/st.tPl)*100):null;
    const bc=pct!==null?(pct>=80?'var(--cp)':pct>=60?'var(--ce)':'var(--ca)'):'#ccc';
    return `<div class="focus-row"><div class="fr-name">${mo}</div><div class="fr-bw"><div class="fr-bar" style="width:${Math.min(pct||0,100)}%;background:${bc};"></div></div><div class="fr-val" style="color:${bc};">${pct!==null?pct+'%':'–'}</div><div style="width:50px;text-align:right;font-size:.61rem;color:var(--gm);">${st.tA}/${st.tPl}${st.mPl?' ⚽'+st.mA+'/'+st.mPl:''}</div></div>`;
  }).join('')||'<p style="font-size:.7rem;color:var(--gm);">Keine Daten.</p>';
  // Focuses
  const focMap={};foc.forEach(f=>focMap[f]={a:0,pl:0});
  tIdx.forEach(i=>{const f=ss[i].focus;if(f&&focMap[f]){if(p.s[i]!==3)focMap[f].pl++;if(p.s[i]===1)focMap[f].a++;}});
  document.getElementById('ps-focuses').innerHTML=foc.filter(f=>focMap[f]&&focMap[f].pl>0).map(f=>{
    const pct=focMap[f].pl?Math.round((focMap[f].a/focMap[f].pl)*100):0;
    return `<div class="focus-row"><div class="fr-name">${f}</div><div class="fr-bw"><div class="fr-bar" style="width:${pct}%;"></div></div><div class="fr-val">${focMap[f].a}/${focMap[f].pl}</div><div style="width:32px;text-align:right;font-size:.61rem;color:var(--gm);">${pct}%</div></div>`;
  }).join('')||'<p style="font-size:.7rem;color:var(--gm);">Noch keine Schwerpunkte erfasst.</p>';
  // Sessions
  document.getElementById('ps-sessions').innerHTML=ss.map((s,i)=>{
    const v=p.s[i];const ssb={1:'ss-a',0:'ss-f',2:'ss-e',3:'ss-q'}[v];const ssl={1:'Anwesend',0:'Fehlend',2:'Entschuldigt',3:'Ausstehend'}[v];
    const isMat=s.type==='match';const lbl=isMat?(s.label||''):(s.focus?`<em>${s.focus}</em>`:'');
    return `<div class="sr"><span class="sr-date">${s.date}</span><span class="sr-type ${isMat?'srt-m':'srt-t'}">${isMat?'⚽':''} ${isMat?'Spiel':'Training'}</span>${lbl?`<span style="font-size:.63rem;color:var(--gm);">${lbl}${isMat&&s.homeAway?(s.homeAway==='home'?' 🏠':' ✈'):''}</span>`:''}<span class="sr-st ${ssb}" style="margin-left:auto;">${ssl}</span></div>`;
  }).join('')||'<p style="padding:9px;font-size:.7rem;color:var(--gm);">Keine Einheiten.</p>';
  openM('moPlayerStats');
}
function savePlayerEdit(){
  const p=cd().players[currentPI];if(!p)return;
  p.nr=parseInt(document.getElementById('ps-edit-nr').value)||p.nr;
  p.name=document.getElementById('ps-edit-name').value.trim()||p.name;
