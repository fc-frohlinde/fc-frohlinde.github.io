    <option value="LF">LF – Linker Flügel</option><option value="ST">ST – Stürmer</option>
  </select>
  <div class="mob-btns">
    <button class="btn btn-p" onclick="addPlayer()">Hinzufügen</button>
    <button class="btn btn-s" onclick="closeM('moAddPlayer')">Abbrechen</button>
  </div>
</div></div>

<!-- Add Training -->
<div class="mo" id="moSession"><div class="mob" style="width:350px;">
  <h3>Training hinzufügen</h3>
  <label>Datum (z.B. Di 07.04)</label>
  <input type="text" id="newDate" placeholder="Di 07.04" maxlength="9"/>
  <label>Schwerpunkt</label>
  <select id="newFocus"><option value="">– Kein –</option></select>
  <p class="note">Monat wird automatisch erkannt. Chronologisch einsortiert.</p>
  <div class="mob-btns">
    <button class="btn btn-p" onclick="addTraining()">Hinzufügen</button>
    <button class="btn btn-s" onclick="closeM('moSession')">Abbrechen</button>
  </div>
</div></div>

<!-- Add Match -->
<div class="mo" id="moMatch"><div class="mob" style="width:360px;">
  <h3>⚽ Spiel hinzufügen</h3>
  <label>Datum (z.B. So 06.04)</label>
  <input type="text" id="newMatchDate" placeholder="So 06.04" maxlength="9"/>
  <label>Gegner</label>
  <input type="text" id="newMatchLabel" placeholder="z.B. FC Westfalia Herne"/>
