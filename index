  <div style="margin-left:auto;"><button class="bsm bsm-o" onclick="openM('moGenSch')">📅 Plan generieren</button></div>
</div>

<!-- COLLAPSE BAR -->
<div class="collapse-bar">
  <span class="cbar-label">ANSICHT:</span>
  <button class="cbar-btn active" id="cb-hdr" onclick="toggleSection('hdr')" title="Header">⬆ Header</button>
  <div class="cbar-sep"></div>
  <button class="cbar-btn active" id="cb-tabs" onclick="toggleSection('tabs')" title="Tabs">Tabs</button>
  <div class="cbar-sep"></div>
  <button class="cbar-btn active" id="cb-tools" onclick="toggleSection('tools')" title="Werkzeuge">Werkzeuge</button>
  <div class="cbar-sep"></div>
  <button class="cbar-btn active" id="cb-legend" onclick="toggleSection('legend')" title="Legende">Legende</button>
  <div class="cbar-sep"></div>
  <button class="cbar-btn" id="cb-all" onclick="toggleAllOff()" title="Alles ausblenden">📋 Tabellenansicht</button>
  <div class="cbar-sep"></div>
  <button class="cbar-btn" onclick="resetCollapse()" title="Alles einblenden">↺ Standard</button>
</div>

<!-- TOOLBAR ROW 1: Team management -->
<div class="toolbar-team" id="toolbarTeamEl">
  <button class="btn btn-p" onclick="openM('moAddPlayer')">＋ Spieler</button>
  <button class="btn btn-s" onclick="openM('moSession')">＋ Einheit</button>
  <button class="btn btn-m" onclick="openM('moMatch')">⚽ Spiel</button>
  <div class="tsep"></div>
  <button class="btn btn-team" onclick="openTeamMgr('spieler')">👥 Mannschaft</button>
  <button class="btn btn-cfg" onclick="openM('moSettings')" title="Einstellungen (Schwerpunkte, Trainer)">⚙ Einstellungen</button>
  <div class="tsep"></div>
  <button class="btn btn-d" onclick="resetTeam()" title="Daten zurücksetzen">↺ Reset</button>
  <span class="saved" id="savedBadge">✓ Gespeichert</span>
</div>

<!-- TOOLBAR ROW 2: Utility -->
<div class="toolbar-util" id="toolbarUtilEl">
  <button class="btn btn-sh" onclick="openM('moShare')">🔗 Teilen</button>
  <div class="tsep"></div>
  <button class="btn btn-s" onclick="window.print()">🖨 Drucken</button>
  <button class="btn btn-s" onclick="exportCSV()">⬇ CSV</button>
  <div class="tsep"></div>
  <div class="zoom-group">
    <button class="z-btn" onclick="changeZoom(-10)">−</button>
    <span class="z-lbl" id="zoomLbl">100%</span>
    <button class="z-btn" onclick="changeZoom(10)">＋</button>
    <button class="z-btn" onclick="changeZoom(0)" style="font-size:.58rem;" title="Reset">⟳</button>
  </div>
</div>

<!-- LEGEND -->
<div class="legend-bar" id="legendEl">
  <span class="lbl">Legende:</span>
  <span class="li"><span class="ldot lda"></span>Anwesend (A)</span>
  <span class="li"><span class="ldot ldf"></span>Fehlend (F)</span>
  <span class="li"><span class="ldot lde"></span>Entschuldigt (E)</span>
  <span class="li"><span class="ldot ldq"></span>Ausstehend (?)</span>
  <span class="lhint">💡 Name / Datum = Details &nbsp;|&nbsp; Pos. = ändern &nbsp;|&nbsp; Zelle = Status</span>
</div>

<!-- TABLE -->
<div class="table-wrap" id="tableWrap">
  <table><thead id="tHead"></thead><tbody id="tBody"></tbody><tfoot id="tFoot"></tfoot></table>
</div>

<!-- FOOTER -->
<div class="footer">
  <div class="fstats" id="fStats"></div>
  <div class="sign"><span id="fTeam">–</span> &nbsp;|&nbsp; Stand: <span id="fDate"></span></div>
</div>
</div>

<!-- ═════════ MODALS ═════════ -->

<!-- Player Stats -->
<div class="mo" id="moPlayerStats"><div class="mob" style="width:500px;">
  <div style="display:flex;align-items:flex-start;gap:10px;margin-bottom:13px;">
    <div style="flex:1;">
      <div style="font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:var(--bd);letter-spacing:2px;line-height:1;" id="ps-name">–</div>
      <div style="display:flex;align-items:center;gap:6px;margin-top:4px;">
        <span style="font-family:'Bebas Neue',sans-serif;font-size:.9rem;color:var(--gm);" id="ps-nr">#–</span>
        <span id="ps-pos-badge"></span>
        <span id="ps-team-badge" style="font-size:.6rem;font-weight:600;color:var(--gm);margin-left:4px;"></span>
      </div>
    </div>
    <button class="btn btn-s" onclick="closeM('moPlayerStats')">✕</button>
  </div>
  <div class="ps-cards" id="ps-cards"></div>
  <div class="sec-title">📅 Monatliche Übersicht</div>
  <div id="ps-months" style="margin-bottom:11px;"></div>
  <div class="sec-title">🎯 Schwerpunkte</div>
  <div id="ps-focuses" style="margin-bottom:11px;"></div>
  <div class="sec-title">📋 Alle Einheiten</div>
